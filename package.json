{
  "name": "raketech-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:digital": "npm run dev --workspace=apps/storefront-digital",
    "dev:physical": "npm run dev --workspace=apps/storefront-physical",
    "dev:admin": "npm run dev --workspace=apps/admin",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "dependencies": {
    "firebase": "^12.12.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19"
  }
}
